generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "zod-prisma"
  output   = "./zod" // (default) the directory where generated zod schemas will be saved

  relationModel = true // (default) Create and export both plain and related models.
  // relationModel         = "default" // Do not export model without relations.
  // relationModel         = false // Do not generate related model

  modelCase = "PascalCase" // (default) Output models using pascal case (ex. UserModel, PostModel)
  // modelCase             = "camelCase" // Output models using camel case (ex. userModel, postModel)

  modelSuffix = "Model" // (default) Suffix to apply to your prisma models when naming Zod schemas

  // useDecimalJs          = false // (default) represent the prisma Decimal type using as a JS number
  useDecimalJs = true // represent the prisma Decimal type using Decimal.js (as Prisma does)

  imports = null // (default) will import the referenced file in generated schemas to be used via imports.someExportedVariable

  // https://www.prisma.io/docs/concepts/components/prisma-client/working-with-fields/working-with-json-fields#filtering-by-null-values
  prismaJsonNullability = true // (default) uses prisma's scheme for JSON field nullability
  // prismaJsonNullability = false // allows null assignment to optional JSON fields
}

datasource db {
  provider = "postgresql"
}

// ─── Settings ────────────────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String
}

// ─── Entra / Azure AD ────────────────────────────────────────────────────────

model EntraIdentity {
  id                String   @id
  displayName       String?
  mail              String?
  userPrincipalName String?
  syncedAt          DateTime @default(now())

  users User[]
}

// ─── OIDC / Generic SSO ───────────────────────────────────────────────────────

model OidcIdentity {
  sub      String   @id     // OIDC subject claim (globally unique per issuer)
  issuer   String           // Issuer URL
  email    String?
  name     String?
  syncedAt DateTime @default(now())

  users User[]
}

// ─── Agents ──────────────────────────────────────────────────────────────────

model Agent {
  did                  String    @id
  name                 String
  publicKey            String?
  capabilities         String[]  @default([])
  certificateData      String?
  llmConfig            Json?
  tokenBudgetDaily     Int?
  tokenBudgetMonthly   Int?
  dailyPriceSpent      Float?    @default(0)
  litellmVirtualKey    String?
  litellmAllowedModels Json      @default("[]")
  litellmDailyBudget   Float?
  litellmKeyUpdatedAt  DateTime?
  registeredAt         DateTime  @default(now())
  lastSeen             DateTime  @default(now())
  locationLat          Float?
  locationLon          Float?
  locationLabel        String?

  agentRealms      AgentRealm[]
  tokenUsage       AgentTokenUsage?
  tokenHistory     AgentTokenUsageHistory[]
  peerGrantsSource AgentPeerGrant[]         @relation("sourcePeerGrants")
  peerGrantsTarget AgentPeerGrant[]         @relation("targetPeerGrants")
  skillOverrides   AgentSkillOverride[]
  knowledgeSources KnowledgeSource[]
}

// ─── Auth sessions ────────────────────────────────────────────────────────────

model AuthSession {
  id              String   @id
  sessionKey      String
  certificateData String   @default("")
  status          Int      @default(-1)
  agentDid        String?
  createdAt       DateTime @default(now())
}

// ─── Certificates ─────────────────────────────────────────────────────────────

model Certificate {
  id           String   @id
  key          String
  registration String?  @unique
  connection   String?  @unique
  register     Int      @default(1)
  data         String   @default("")
  status       Int      @default(-1)
  metadata     String?
  startedAt    DateTime @default(now())
}

// ─── Activity log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        Int      @id @default(autoincrement())
  event     String
  agentDid  String?
  agentName String?
  details   String?
  createdAt DateTime @default(now())
}

// ─── Pending registrations ───────────────────────────────────────────────────

model PendingRegistration {
  id                    String   @id
  sessionId             String
  agentName             String
  status                String   @default("pending")
  requestedCapabilities Json     @default("[]")
  assignedCapabilities  Json     @default("[]")
  createdAt             DateTime @default(now())
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  did           String?   @unique
  publicKey     String?
  name          String?
  email         String?
  isOwner       Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  role          String    @default("member")
  reportsTo     String?
  description   String?
  entraId       String?
  oidcId        String?
  claimedAt     DateTime?
  registeredAt  DateTime  @default(now())
  locationLat   Float?
  locationLon   Float?
  locationLabel String?

  manager         User?            @relation("reportsTo", fields: [reportsTo], references: [id], onDelete: SetNull)
  reports         User[]           @relation("reportsTo")
  entraIdentity   EntraIdentity?   @relation(fields: [entraId], references: [id], onDelete: SetNull)
  oidcIdentity    OidcIdentity?    @relation(fields: [oidcId], references: [sub], onDelete: SetNull)
  userRealms      UserRealm[]
  userGrants      UserGrant[]
  invitations     UserInvitation[]

  @@index([did])
  @@index([entraId])
  @@index([oidcId])
}

// ─── User grants & delegation certs ──────────────────────────────────────────

model UserGrant {
  id           String    @id
  userDid      String
  agentDid     String?
  capabilities Json      @default("[]")
  grantedBy    String
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user            User             @relation(fields: [userDid], references: [did], onDelete: Cascade)
  delegationCerts DelegationCert[]
}

model DelegationCert {
  id           String    @id
  grantId      String
  userDid      String
  agentDid     String
  capabilities Json      @default("[]")
  certificate  String
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  grant UserGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)
}

// ─── Agent peer grants ────────────────────────────────────────────────────────

model AgentPeerGrant {
  id               String    @id
  sourceDid        String
  targetDid        String
  targetName       String
  skillDescription String
  capabilities     Json      @default("[]")
  certificate      String    @default("")
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  sourceAgent Agent @relation("sourcePeerGrants", fields: [sourceDid], references: [did], onDelete: Cascade)
  targetAgent Agent @relation("targetPeerGrants", fields: [targetDid], references: [did], onDelete: Cascade)

  @@index([sourceDid])
  @@index([targetDid])
}

// ─── Token usage ──────────────────────────────────────────────────────────────

model AgentTokenUsage {
  agentDid         String   @id
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  updatedAt        DateTime @default(now())

  agent Agent @relation(fields: [agentDid], references: [did], onDelete: Cascade)
}

model AgentTokenUsageHistory {
  agentDid         String
  bucket           String
  granularity      String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  updatedAt        DateTime @default(now())

  agent Agent @relation(fields: [agentDid], references: [did], onDelete: Cascade)

  @@id([agentDid, bucket, granularity])
  @@index([agentDid, granularity, bucket])
}

// ─── Realms ───────────────────────────────────────────────────────────────────

model Realm {
  id                  String   @id
  name                String
  slug                String   @unique
  description         String?
  color               String   @default("#6366f1")
  isDefault           Boolean  @default(false)
  llmConfig           Json?
  defaultCapabilities Json     @default("[]")
  tokenBudgetDaily    Int?
  tokenBudgetMonthly  Int?
  allowedCapabilities Json?
  createdAt           DateTime @default(now())

  tokenUsage       RealmTokenUsage?
  agentRealms      AgentRealm[]
  userRealms       UserRealm[]
  realmSkills      RealmSkill[]
  knowledgeSources KnowledgeSource[]
  channels         Channel[]
  credentials      Credential[]
  modelAccess      ModelRealmAccess[]
  routerKey        RealmRouterKey?
  policies         Policy[]
  workflows        Workflow[]
}

model RealmTokenUsage {
  realmId          String   @id
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  updatedAt        DateTime @default(now())

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)
}

// ─── Agent & User realm membership ───────────────────────────────────────────

model AgentRealm {
  agentDid  String
  realmId   String
  isPrimary Boolean  @default(false)
  joinedAt  DateTime @default(now())

  agent Agent @relation(fields: [agentDid], references: [did], onDelete: Cascade)
  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@id([agentDid, realmId])
}

model UserRealm {
  userId       String
  realmId      String
  isPrimary    Boolean  @default(false)
  isRealmAdmin Boolean  @default(false)
  joinedAt     DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@id([userId, realmId])
}

// ─── Skills ───────────────────────────────────────────────────────────────────

model OrgSkill {
  id           String   @id
  name         String   @unique
  description  String?
  version      String   @default("1.0.0")
  icon         String?
  content      String?
  configSchema Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model RealmSkill {
  id          String   @id
  realmId     String
  name        String
  description String?
  version     String?
  isRequired  Boolean  @default(false)
  config      Json     @default("{}")
  content     String?
  createdAt   DateTime @default(now())

  realm          Realm                @relation(fields: [realmId], references: [id], onDelete: Cascade)
  agentOverrides AgentSkillOverride[]

  @@unique([realmId, name])
}

model AgentSkillOverride {
  agentDid     String
  realmSkillId String
  enabled      Boolean @default(true)

  agent      Agent      @relation(fields: [agentDid], references: [did], onDelete: Cascade)
  realmSkill RealmSkill @relation(fields: [realmSkillId], references: [id], onDelete: Cascade)

  @@id([agentDid, realmSkillId])
}

// ─── Model registry ───────────────────────────────────────────────────────────

model ModelRegistry {
  id               String   @id
  name             String
  description      String?
  provider         String
  modelId          String
  baseUrl          String
  apiKeyEnc        String?
  litellmModelName String?
  status           String   @default("active")
  metadata         Json     @default("{}")
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  realmAccess ModelRealmAccess[]

  @@index([status])
}

model ModelRealmAccess {
  modelId   String
  realmId   String
  grantedAt DateTime @default(now())

  model ModelRegistry @relation(fields: [modelId], references: [id], onDelete: Cascade)
  realm Realm         @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@id([modelId, realmId])
  @@index([realmId])
}

model RealmRouterKey {
  realmId           String   @id
  litellmVirtualKey String?
  allowedModelIds   Json     @default("[]")
  monthlyBudgetUsd  Float?
  updatedAt         DateTime @default(now())

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)
}

// ─── Policies ─────────────────────────────────────────────────────────────────

model Policy {
  id             String    @id
  agentDid       String?
  realmId        String?
  capabilities   Json      @default("[]")
  resourceLimits Json?
  expiresAt      DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())

  realm Realm? @relation(fields: [realmId], references: [id], onDelete: SetNull)

  @@index([agentDid])
  @@index([realmId])
}

// ─── Workflows ────────────────────────────────────────────────────────────────

model Workflow {
  id              String    @id
  name            String
  description     String?
  definition      Json
  realmId         String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  scheduleCron    String?
  scheduleEnabled Boolean   @default(false)
  scheduleLastRun DateTime?
  scheduleNextRun DateTime?

  realm Realm?        @relation(fields: [realmId], references: [id], onDelete: SetNull)
  runs  WorkflowRun[]

  @@index([createdBy, createdAt(sort: Desc)])
  @@index([realmId])
}

model WorkflowRun {
  id          String    @id
  workflowId  String
  status      String    @default("running")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  results     Json?

  workflow  Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps     WorkflowStep[]
  approvals WorkflowApproval[]

  @@index([workflowId, startedAt(sort: Desc)])
}

model WorkflowStep {
  id          String    @id
  runId       String
  stepId      String
  agentId     String?
  status      String    @default("pending")
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, stepId])
}

model WorkflowApproval {
  id             String    @id
  runId          String
  stepId         String
  workflowId     String
  workflowName   String
  nodeMessage    String?
  stepInput      String?
  assignedUserId String
  mode           String    @default("approval")
  status         String    @default("pending")
  decidedAt      DateTime?
  decidedBy      String?
  comment        String?
  createdAt      DateTime  @default(now())

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([assignedUserId, status])
  @@index([runId])
}

// ─── Intent log ───────────────────────────────────────────────────────────────

model IntentLog {
  intentId    String    @id
  agentDid    String?
  action      String
  params      Json?
  status      String    @default("pending")
  output      Json?
  error       String?
  signature   String?
  sentAt      DateTime  @default(now())
  completedAt DateTime?

  @@index([agentDid, sentAt(sort: Desc)])
  @@index([status, sentAt(sort: Desc)])
}

// ─── User invitations ─────────────────────────────────────────────────────────

model UserInvitation {
  token     String    @id
  email     String
  name      String
  role      String    @default("member")
  createdAt DateTime  @default(now())
  expiresAt DateTime
  claimedAt DateTime?
  userId    String?

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expiresAt])
  @@index([userId])
}

// ─── Knowledge ────────────────────────────────────────────────────────────────

model KnowledgeSource {
  id           String    @id
  realmId      String
  agentDid     String
  name         String
  sourceType   String
  config       Json      @default("{}")
  status       String    @default("idle")
  docCount     Int       @default(0)
  chunkCount   Int       @default(0)
  lastSyncedAt DateTime?
  error        String?
  createdAt    DateTime  @default(now())

  realm Realm           @relation(fields: [realmId], references: [id], onDelete: Cascade)
  agent Agent           @relation(fields: [agentDid], references: [did], onDelete: Cascade)
  files KnowledgeFile[]

  @@index([realmId])
  @@index([agentDid])
}

model KnowledgeFile {
  id        String   @id
  sourceId  String
  name      String
  mimeType  String   @default("application/octet-stream")
  size      Int      @default(0)
  content   Bytes?
  filePath  String?
  createdAt DateTime @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
}

// ─── Channels ─────────────────────────────────────────────────────────────────

model Channel {
  id          String   @id
  realmId     String?
  name        String
  slug        String
  description String?
  isPublic    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  topic       String?
  creatorDid  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  realm    Realm?           @relation(fields: [realmId], references: [id], onDelete: Cascade)
  members  ChannelMember[]
  messages ChannelMessage[]
  bridges  ChannelBridge[]

  @@unique([realmId, slug])
  @@index([realmId])
  @@index([slug])
}

model ChannelMember {
  id         String   @id
  channelId  String
  memberDid  String
  memberType String
  role       String   @default("member")
  joinedAt   DateTime @default(now())
  invitedBy  String?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, memberDid])
  @@index([channelId])
  @@index([memberDid])
}

model ChannelMessage {
  id         String    @id
  channelId  String
  threadId   String?
  authorDid  String
  authorType String
  content    String
  metadata   Json      @default("{}")
  reactions  Json      @default("{}")
  editedAt   DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  channel Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  thread  ChannelMessage?  @relation("threadMessages", fields: [threadId], references: [id])
  replies ChannelMessage[] @relation("threadMessages")

  @@index([channelId, createdAt(sort: Desc)])
  @@index([threadId])
  @@index([authorDid])
}

model ChannelBridge {
  id                  String   @id
  channelId           String
  externalService     String
  externalChannelId   String
  externalChannelName String
  externalWorkspaceId String
  syncDirection       String   @default("bidirectional")
  isSyncEnabled       Boolean  @default(true)
  createdAt           DateTime @default(now())
  configJson          Json

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, externalService, externalChannelId])
  @@index([channelId])
}

// ─── Credentials vault ────────────────────────────────────────────────────────

model Credential {
  id        String   @id
  realmId   String
  service   String
  name      String
  secretEnc String
  metadata  Json     @default("{}")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  realm Realm @relation(fields: [realmId], references: [id], onDelete: Cascade)

  @@unique([realmId, service, name])
  @@index([realmId])
  @@index([service])
}

// ─── API keys ─────────────────────────────────────────────────────────────────

model ApiKey {
  id            String    @id
  name          String
  keyHash       String    @unique
  keyPrefix     String
  allowedRoutes Json      @default("[]")
  realmId       String?
  isRealmAdmin  Boolean   @default(false)
  createdBy     String
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)

  @@index([keyHash])
  @@index([realmId])
}
