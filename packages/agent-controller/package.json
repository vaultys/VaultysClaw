{
  "name": "@vaultysclaw/agent-controller",
  "version": "0.0.1",
  "description": "Agent controller for running LLMs with secure orchestration",
  "main": "dist/index.js",
  "bin": {
    "agent-controller": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:tui": "tsx src/cli.ts --mode tui",
    "dev:web": "VAULTYS_ID_PATH=./.vaultys/agent-web2.id AGENT_NAME=agent-web tsx src/web-launcher.ts",
    "build:web": "cd web-app && vite build",
    "dev:web-client": "cd web-app && vite",
    "build": "tsc",
    "build:binaries": "bash scripts/build-binaries.sh",
    "start": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "spawn": "tsx src/cli.ts --spawn",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai": "^3.0.64",
    "@mastra/core": "^1.35.0",
    "@msgpack/msgpack": "^3.1.3",
    "@roamhq/wrtc": "^0.10.0",
    "@vaultys/channel-peerjs": "^2.4.3",
    "peerjs": "^1.5.5",
    "@vaultys/id": "3.0.0-beta6",
    "@vaultysclaw/shared": "workspace:*",
    "ai": "^6.0.169",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "open": "^10.1.0",
    "pino": "^10.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^9.0.1",
    "playwright": "^1.49.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.10.0",
    "eslint": "^10.2.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}