{
  "name": "vaultysclaw",
  "version": "0.0.1",
  "description": "Decentralized AI agent orchestration platform with secure control plane",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "-- DEV --": "",
    "vaultysclaw:dev": "pnpm --filter @vaultysclaw/control-plane dev --data-dir ../../.devdata | pino-pretty",
    "agent:dev": "pnpm --filter @vaultysclaw/agent-controller dev",
    "agent:start": "pnpm --filter @vaultysclaw/agent-controller start",
    "agent:web": "pnpm --filter @vaultysclaw/agent-controller dev:web",
    "agent:tui": "pnpm --filter @vaultysclaw/agent-controller dev:tui",
    "agent:spawn": "pnpm --filter @vaultysclaw/agent-controller spawn",
    "dev": "turbo run dev",
    "-- BUILD --": "",
    "build": "turbo run build",
    "agent:build:binaries": "pnpm --filter @vaultysclaw/agent-controller build:binaries",
    "-- QUALITY --": "",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write .",
    "-- TEST --": "",
    "test": "vitest --no-watch",
    "test:ui": "vitest --ui",
    "test:components": "vitest --config vitest.config.ui.mjs --run",
    "test:coverage": "vitest --coverage",
    "test:packages": "turbo run test",
    "test:docker": "vitest --config vitest.config.docker.mjs --run",
    "test:litellm": "vitest --config vitest.config.litellm.mjs --run",
    "-- MISC --": "",
    "swagger:generate": "pnpm tsx scripts/generate-swagger-docs.ts",
    "swagger:check": "pnpm tsx scripts/generate-swagger-docs.ts --check",
    "migrate:api-client": "jscodeshift -t scripts/migrate-fetch-to-api-client.mjs --extensions=tsx,ts --parser=tsx packages/control-plane/app",
    "migrate:api-client:dry": "jscodeshift -t scripts/migrate-fetch-to-api-client.mjs --extensions=tsx,ts --parser=tsx --dry packages/control-plane/app",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vaultys/id": "3.0.0-beta6",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3",
    "jscodeshift": "^17.3.0",
    "vitest": "^2.1.9",
    "ws": "^8.20.1"
  }
}
