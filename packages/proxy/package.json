{
  "name": "@vaultysclaw/proxy",
  "version": "0.0.1",
  "description": "VaultysClaw proxy — a governance-gated reverse proxy that connects to the control plane like an agent, verifies and authorizes API traffic locally, and reports activity async",
  "type": "module",
  "bin": {
    "vaultysclaw-proxy": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@vaultys/id": "3.0.0-beta6",
    "@vaultysclaw/policy": "workspace:*",
    "@vaultysclaw/sdk": "workspace:*",
    "@vaultysclaw/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
