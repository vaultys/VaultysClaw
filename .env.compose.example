# VaultysClaw all-in-one stack — environment overrides
# Copy to .env.compose and pass with: docker compose --env-file .env.compose up
#
# All variables have insecure defaults that work for local dev.
# Change these before exposing to a network.

# PostgreSQL
PG_PASSWORD=change_me_strong_password
PG_PORT=5432

# Redis (BullMQ queue + notification pub/sub)
# REDIS_URL is the in-network URL used by services (compose DNS name "redis").
# REDIS_PORT is only the host-side port for debugging; 6380 avoids clashing with
# a local Redis already bound to 6379.
REDIS_URL=redis://redis:6379
REDIS_PORT=6380

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# LiteLLM master key — used by control plane to call the proxy
LITELLM_MASTER_KEY=sk-your-master-key-here

# MinIO credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
