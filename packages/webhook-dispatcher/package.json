{
  "name": "@vaultysclaw/webhook-dispatcher",
  "version": "0.0.1",
  "description": "Webhook dispatcher service — consumes webhook events from BullMQ, signs them (HMAC) and POSTs them to configured endpoints",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vaultysclaw/shared": "workspace:*",
    "bullmq": "^5.80.0",
    "ioredis": "^5.10.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
