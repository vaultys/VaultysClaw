{
  "name": "@vaultysclaw/control-plane",
  "version": "0.0.1",
  "description": "Control plane for VaultysClaw - manage policies, agents, and AI orchestration",
  "scripts": {
    "postinstall": "prisma generate && sed -i \"/import \\* as imports from \\\"..\\/null\\\"/d\" prisma/zod/*.ts",
    "prisma:generate": "prisma generate && sed -i \"/import \\* as imports from \\\"..\\/null\\\"/d\" prisma/zod/*.ts",
    "dev": "tsx watch --exclude 'data*/**' --exclude '.next/**' server.ts",
    "build": "tsc && next build",
    "start": "node dist/server.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@msgpack/msgpack": "^3.1.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@roamhq/wrtc": "^0.10.0",
    "@tailwindcss/typography": "^0.5.19",
    "@ts-rest/core": "^3.52.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@vaultys/channel-browser": "^2.4.2",
    "@vaultys/channel-peerjs": "^2.4.3",
    "@vaultys/id": "3.0.0-beta6",
    "@vaultysclaw/shared": "workspace:*",
    "axios": "^1.16.1",
    "dotenv": "^16.6.1",
    "expr-eval": "^2.0.2",
    "geoip-lite": "^2.0.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.7",
    "ol": "^10.9.0",
    "peerjs": "^1.5.5",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^9.1.0",
    "react-simple-maps": "^3.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-react": "^5.32.6",
    "tailwindcss": "^3.4.19",
    "three": "^0.184.0",
    "ws": "^8.20.1",
    "zod": "^3.25.76",
    "zod-prisma": "^0.5.4",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/expr-eval": "^1.1.2",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
