# VaultysClaw Agent Controller — Environment Variables
AGENT_NAME=my-agent
CONTROL_PLANE_URL=http://localhost:3000
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
# LLM_BASE_URL=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Set to true to enable tracing export
OTEL_ENABLED=false
# OTLP/HTTP endpoint — must match the control plane's endpoint so traces are correlated
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=vaultysclaw-agent
