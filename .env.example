# Control Plane
CONTROL_PLANE_PORT=3300
CONTROL_PLANE_DATABASE_URL=sqlite:./data.db
CONTROL_PLANE_VAULTYS_ID_PATH=./.vaultys/control-plane.id

# WebSocket Server (for Agent Connections)
CONTROL_PLANE_WS_HOST=localhost
