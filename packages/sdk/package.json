{
  "name": "@vaultysclaw/sdk",
  "version": "0.0.1",
  "description": "VaultysClaw SDK — VaultysId identity, control-plane connection (WS/WebRTC), and policy engine execution for building agents, gateways, or custom integrations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": { "build": "tsc", "type-check": "tsc --noEmit" },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@vaultys/channel-peerjs": "^2.4.3",
    "@vaultys/id": "3.0.0-beta6",
    "@vaultysclaw/policy": "workspace:*",
    "@vaultysclaw/shared": "workspace:*",
    "peerjs": "^1.5.5",
    "pino": "^10.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
